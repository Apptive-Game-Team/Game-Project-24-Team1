{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "2b0b21e26aa54aeeb049698e379f73c0",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GetMainLight (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -923.0000610351563,
            "y": 390.00006103515627,
            "width": 256.0,
            "height": 142.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "dde7dfacdad24ead8bcf231594dea46d"
        },
        {
            "m_Id": "5f610e817d9d4c85b9f59218b785b79e"
        },
        {
            "m_Id": "e3c8101cb30a43189e0be76a56655b1c"
        },
        {
            "m_Id": "0b9d0152c2634bac898f268d32ea2857"
        },
        {
            "m_Id": "07e3bb026afa445584233050c017d8d9"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 1,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetMainLight",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// [GetMainLight 커스텀 펑션 코드]\r\n#if SHADERGRAPH_PREVIEW\r\n    MainDirection = float3(0.5, 0.5, 0);\r\n    MainColor = float3(1, 1, 1);\r\n    AddLightsColor = float3(0, 0, 0);\r\n#else\r\n    // 월드 좌표를 그림자 맵 상의 좌표로 변환\r\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPosition);\r\n    \r\n    // 이제 mainLight는 벽(Static)에 가려진 정보를 정확히 포함합니다.\r\n    Light mainLight = GetMainLight(shadowCoord);\r\n    \r\n    MainDirection = mainLight.direction;\r\n    // 팁: 그림자가 너무 새카맣게 나오면 shadowAttenuation에 0.2 정도를 더해 조절 가능합니다.\r\n    MainColor = mainLight.color * mainLight.shadowAttenuation;\r\n\r\n    // 추가 조명(손전등 등) 계산\r\n    float3 additionalColor = float3(0, 0, 0);\r\n    uint lightCount = GetAdditionalLightsCount();\r\n    for (uint i = 0; i < lightCount; ++i)\r\n    {\r\n        Light light = GetAdditionalLight(i, WorldPosition);\r\n        #if defined(_ADDITIONAL_LIGHT_SHADOWS)\r\n            light.shadowAttenuation = AdditionalLightRealtimeShadow(i, WorldPosition, light.direction);\r\n        #endif\r\n        float NdotL = dot(WorldNormal, light.direction);\r\n        float toonEffect = step(0.01, NdotL);\r\n        additionalColor += light.color * toonEffect * (light.distanceAttenuation * light.shadowAttenuation);\r\n    }\r\n    AddLightsColor = additionalColor;\r\n#endif"
}

